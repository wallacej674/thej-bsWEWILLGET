ENVIRONMENT=development
APP_NAME=ApplyTogether API
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://applytogether:applytogether@127.0.0.1:5434/applytogether
DEV_IDENTITY_HEADER_ENABLED=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
AUTH_JWT_SECRET_KEY=generate-a-long-random-secret-and-keep-it-out-of-git
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=20
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-google-account@gmail.com
SMTP_APP_PASSWORD=your-16-character-google-app-password
SMTP_FROM_EMAIL=your-google-account@gmail.com
SMTP_FROM_NAME=ApplyTogether
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=15
FRONTEND_BASE_URL=http://localhost:5173
EMAIL_VERIFICATION_HOURS=24
EMAIL_RESEND_COOLDOWN_SECONDS=60
LOG_LEVEL=INFO
APP_TIMEZONE=America/Chicago
SEED_JONATHAN_EMAIL=jonathan@example.test
SEED_JONATHAN_DISPLAY_NAME=Jonathan
SEED_KAREEM_EMAIL=kareem@example.test
SEED_KAREEM_DISPLAY_NAME=Kareem
