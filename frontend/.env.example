VITE_API_BASE_URL=http://localhost:8000
# Developer-only; never enable in production builds.
VITE_ENABLE_DEV_IDENTITY_SWITCHER=false
# Only required when the developer identity adapter is explicitly enabled.
VITE_JONATHAN_USER_ID=
VITE_KAREEM_USER_ID=
VITE_CSRF_COOKIE_NAME=applytogether_csrf
VITE_CSRF_HEADER_NAME=X-CSRF-Token
VITE_REFRESH_CSRF_COOKIE_NAME=applytogether_refresh_csrf
VITE_REFRESH_CSRF_HEADER_NAME=X-Refresh-CSRF-Token
